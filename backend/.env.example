# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="Idea Evolution Engine API"
APP_VERSION=0.1.0
APP_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_NAME=idea_evolution.db

# ── CORS ──────────────────────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Model profile ─────────────────────────────────────────────────────────────
# Select the AI model profile based on your available hardware.
#
#   capable  -- llama3.1:latest  (~17 GB VRAM, RX 7900 XT / RTX 3090+)
#              Best response quality. Requires: ollama pull llama3.1
#
#   fast     -- qwen2.5          (~5 GB VRAM or CPU-only)
#              Faster, lower resource usage. Requires: ollama pull qwen2.5
#
MODEL_PROFILE=capable

# ── Overrides (optional) ──────────────────────────────────────────────────────
# These override the profile values above if set.
# OLLAMA_MODEL=llama3.1:latest
# OLLAMA_TIMEOUT=180
